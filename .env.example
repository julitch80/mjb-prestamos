# Copia este archivo como .env.local y completa los valores
# .env.local NO se sube a GitHub (está en .gitignore)

VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec
VITE_SHEETS_ID=TU_GOOGLE_SHEETS_ID
VITE_SENTRY_DSN=https://tu_clave@sentry.io/tu_proyecto

# Firebase (Etapa 1+). Copiar a .env y rellenar con el objeto firebaseConfig de la consola.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Modo de autenticación durante la transición: pin (actual) | google
VITE_AUTH_MODE=pin
